{
  "name": "mise",
  "version": "0.1.0",
  "private": true,
  "description": "Dev tooling only — the app itself is zero-build static files. Nothing here ships.",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit -p jsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write \"app/**/*.{js,css,html,json}\" \"docs/**/*.md\""
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.6.0",
    "htm": "3.1.1",
    "preact": "10.29.4",
    "prettier": "3.9.4",
    "typescript": "6.0.3"
  }
}
